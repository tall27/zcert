# zcert Profile Configuration File
# This file supports multiple profiles with different ZTPKI settings
# Use: zcert --config zcert.cnf --profile Default enroll --cn "mycert.com"
#   or zcert --config zcert.cnf --profile staging enroll --cn "mycert.com"

[Default]
# Default profile used when no --profile is specified
base_url = "https://ztpki-dev.venafi.com/api/v2"
hawk_id = "165c01284c6c8d872091aed0c7cc0149"
hawk_key = "b97a01107585f1f037a65fafe334dcda6a42b156e1ae8df0072d203dd36f5c0c"
default_key_size = 2048
default_key_type = "rsa"
default_format = "pem"
default_policy_id = "5fe6d368-896a-4883-97eb-f87148c90896"

[staging]
# Profile for staging environment
base_url = "https://ztpki-staging.venafi.com/api/v2"
hawk_id = "165c0128424432112372091aed0c7cc0149"
hawk_key = "b97a011123123dedwe12334dcda6a42b156e1ae8df0072d203dd36f5c0c"
default_key_size = 2048
default_key_type = "rsa"
default_format = "p12"
default_policy_id = "5fe6d368-896a-4883-97eb-f87148c90896"

[production]
# Profile for production environment
base_url = "https://ztpki-prod.venafi.com/api/v2"
hawk_id = "prod-hawk-id-here"
hawk_key = "prod-hawk-key-here"
default_key_size = 4096
default_key_type = "rsa"
default_format = "pem"
default_policy_id = ""

[p12]
# Profile for PKCS#12 certificates
base_url = "https://ztpki-dev.venafi.com/api/v2"
hawk_id = "165c01284c6c8d872091aed0c7cc0149"
hawk_key = "b97a01107585f1f037a65fafe334dcda6a42b156e1ae8df0072d203dd36f5c0c"
default_key_size = 2048
default_key_type = "rsa"
default_format = "p12"
default_policy_id = "5fe6d368-896a-4883-97eb-f87148c90896"
p12_password = "changeme"